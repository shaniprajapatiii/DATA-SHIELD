# DataShield Backend Environment Template

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/datashield

# JWT Configuration
JWT_SECRET=your_secure_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=5000
NODE_ENV=development

# Client Configuration
CLIENT_URL=http://localhost:3000

# Python Engine Configuration
PYTHON_ENGINE_URL=http://localhost:8000

# Scan Limits (default values in config/constants.js override these if not set)
# Free plan: 10 scans/month
# Pro plan: 200 scans/month
# Enterprise: Unlimited
