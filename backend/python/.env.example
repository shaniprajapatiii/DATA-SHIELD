# ─── Server Configuration ───────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ENV=development

# ─── Logging ────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ─── Web Scraping ───────────────────────────────────────────────────
REQUEST_TIMEOUT=15
MAX_RETRIES=3
MAX_REQUESTS_PER_MINUTE=30
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# ─── NLP Models & Features ──────────────────────────────────────────
USE_SPACY=true
USE_TRANSFORMERS=true
USE_VADER=true

# Spacy Model
SPACY_MODEL=en_core_web_sm

# Transformer Model
TRANSFORMER_MODEL=nlptown/bert-base-multilingual-uncased-sentiment

# ─── Cache Configuration ────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0
# CACHE_TTL=3600

# ─── CORS Configuration ─────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000,https://datashield.app

# ─── Database (Optional) ────────────────────────────────────────────
# MONGODB_URL=mongodb://localhost:27017/datashield
# MONGODB_URL=mongodb+srv://user:pass@cluster.mongodb.net/datashield

# ─── Feature Flags ──────────────────────────────────────────────────
ENABLE_BATCH_PROCESSING=true
ENABLE_POLICY_TRACKING=true
ENABLE_HISTORICAL_ANALYSIS=true
MAX_BATCH_SIZE=10

# ─── Performance Tuning ─────────────────────────────────────────────
# Number of concurrent scraping tasks
MAX_CONCURRENT_TASKS=5

# Processing timeout (seconds)
PROCESSING_TIMEOUT=60

# ─── Monitoring & Debugging ────────────────────────────────────────
DEBUG=false
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
